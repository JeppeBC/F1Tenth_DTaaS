          <mxGeometry x="1500" y="530" width="200" height="60" as="geometry" />
        </mxCell>

        <!-- VESC (car) -->
        <mxCell id="vesc" value="VESC driver&#xa;(motors)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#2A9D3F;fontSize=12;fontStyle=1;strokeWidth=2;" vertex="1" parent="1">
