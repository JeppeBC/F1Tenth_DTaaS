        <!-- ══════════════════════════════════════════════════════════ -->

        <!-- V2P: dt_pt_bridge → dt_pt_listener  (UDP :9870) -->
        <mxCell id="e_v2p" value="UDP :9870  V2P" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#b85450;strokeWidth=3;fontStyle=1;fontSize=11;fontColor=#b85450;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="dt_pt_bridge" target="dt_listener" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1000" y="567" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- P2V echo: dt_pt_listener → dt_pt_bridge  (UDP echo-back) -->
        <mxCell id="e_echo_back" value="UDP echo-back (RTT)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#9673a6;strokeWidth=2;dashed=1;fontStyle=2;fontSize=10;fontColor=#9673a6;exitX=0;exitY=1;exitDx=0;exitDy=0;entryX=1;entryY=1;entryDx=0;entryDy=0;" edge="1" source="dt_listener" target="dt_pt_bridge" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1240" y="630" />
              <mxPoint x="1080" y="630" />
              <mxPoint x="1080" y="630" />
              <mxPoint x="820" y="630" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- P2V odom: odom → gym_bridge  (UDP :9871) -->
        <mxCell id="e_odom_dt" value="UDP :9871  P2V odom" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#2A9D3F;strokeWidth=2;dashed=1;fontStyle=2;fontSize=10;fontColor=#2A9D3F;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="odom" target="gym_bridge" parent="1">
          <mxGeometry relative="1" as="geometry">
