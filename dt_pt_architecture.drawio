        <mxCell id="gym_bridge" value="gym_bridge&#xa;(Digital Twin / RViz2)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#2A9D3F;fontSize=12;fontStyle=1;strokeWidth=2;" vertex="1" parent="1">
