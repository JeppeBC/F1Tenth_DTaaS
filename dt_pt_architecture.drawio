        <!-- ══════════════════════════════════════════════════════════ -->

        <!-- keyboard → /teleop (WSL2) -->
        <mxCell id="e_kb_tel" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#0057A3;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="keyboard" target="teleop_wsl" parent="1">
          <mxCell as="geometry" />
        </mxCell>

        <!-- /teleop (WSL2) → relay -->
        <mxCell id="e_tel_relay" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#d6b656;strokeWidth=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="teleop_wsl" target="relay" parent="1">
          <mxCell as="geometry" />
        </mxCell>

        <!-- relay → /drive (WSL2) -->
        <mxCell id="e_relay_drive" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#82b366;strokeWidth=2;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="relay" target="drive_wsl" parent="1">
          <mxCell as="geometry" />
        </mxCell>

        <!-- /drive (WSL2) → gym_bridge -->
        <mxCell id="e_drive_gym" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#2A9D3F;strokeWidth=2;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="drive_wsl" target="gym_bridge" parent="1">
          <mxCell as="geometry" />
        </mxCell>

        <!-- /drive (WSL2) → dt_pt_bridge -->
        <mxCell id="e_drive_bridge" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#b85450;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="drive_wsl" target="dt_pt_bridge" parent="1">
          <mxGeometry relative="1" as="geometry">
