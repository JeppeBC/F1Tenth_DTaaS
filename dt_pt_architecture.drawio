        <mxCell id="l5" value="🟣  Latency measurement — /teleop_echo RTT" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=11;fontColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="1280" y="1042" width="380" height="24" as="geometry" />
        </mxCell>
        <mxCell id="l6" value="Ellipses = ROS topics  |  Rounded rectangles = nodes" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=11;fontStyle=2;" vertex="1" parent="1">
