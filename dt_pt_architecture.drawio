          </mxGeometry>
        </mxCell>

        <!-- ack_mux → /ackermann_cmd -->
        <mxCell id="e_mux_cmd" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#d79b00;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="ack_mux" target="ack_cmd" parent="1">
