        <!-- ══════════════════════════════════════════════════════════ -->

        <!-- /drive (WSL2) -->
        <mxCell id="drive_wsl" value="/drive&#xa;AckermannDriveStamped" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="210" y="390" width="240" height="70" as="geometry" />
        </mxCell>

        <!-- /drive (car) — navigation slot p=10 -->
