        </mxCell>

        <!-- DDS bleed: /teleop (car) → /teleop (WSL2) -->
        <mxCell id="e_dds" value="DDS bleed (domain 0)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#d6b656;strokeWidth=2;dashed=1;fontStyle=2;fontSize=10;fontColor=#b8860b;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="teleop_car" target="teleop_wsl" parent="1">
          <mxGeometry relative="1" as="geometry">
