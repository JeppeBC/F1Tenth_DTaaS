          <mxCell as="geometry" />
        </mxCell>

        <!-- /teleop (car) → ack_mux -->
        <mxCell id="e_tel_mux" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeColor=#d79b00;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=1;entryY=0;entryDx=0;entryDy=0;" edge="1" source="teleop_car" target="ack_mux" parent="1">
