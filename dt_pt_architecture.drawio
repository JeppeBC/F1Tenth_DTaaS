        <mxCell id="dt_pt_bridge" value="dt_pt_bridge" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontStyle=1;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="560" y="540" width="220" height="55" as="geometry" />
        </mxCell>

        <!-- dt_pt_listener (car) -->
