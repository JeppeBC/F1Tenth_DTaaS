<mxfile host="app.diagrams.net" version="21.0.0">
  <diagram name="DT-PT Architecture" id="dt-pt-arch">
    <mxGraphModel dx="1800" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2200" pageHeight="1100" math="0" shadow="0">
