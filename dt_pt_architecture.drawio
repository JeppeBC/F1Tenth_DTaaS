          <mxGeometry x="60" y="1042" width="240" height="24" as="geometry" />
        </mxCell>
        <mxCell id="l2" value="╌╌  DDS bleed / UDP (cross-boundary)" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="320" y="1042" width="300" height="24" as="geometry" />
        </mxCell>
        <mxCell id="l3" value="🔴  V2P path — DT command → PT" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=11;fontColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="640" y="1042" width="300" height="24" as="geometry" />
        </mxCell>
        <mxCell id="l4" value="🟢  P2V path — PT odom → DT mirror" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=11;fontColor=#2A9D3F;" vertex="1" parent="1">
          <mxGeometry x="960" y="1042" width="300" height="24" as="geometry" />
