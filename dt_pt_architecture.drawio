        <!-- ══════════════════════════════════════════════════════════ -->

        <!-- relay (WSL2) -->
        <mxCell id="relay" value="topic_tools relay&#xa;/teleop → /drive" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="560" y="250" width="220" height="55" as="geometry" />
        </mxCell>

        <!-- ackermann_mux (car) -->
        <mxCell id="ack_mux" value="ackermann_mux&#xa;/teleop  priority=90&#xa;/drive   priority=10" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;fontStyle=1;strokeWidth=2;" vertex="1" parent="1">
