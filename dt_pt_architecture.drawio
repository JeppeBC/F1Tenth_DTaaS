          <mxGeometry x="1280" y="540" width="240" height="55" as="geometry" />
        </mxCell>

        <!-- ══════════════════════════════════════════════════════════ -->
        <!-- ROW 7 — echo + logger + odom                              -->
        <!-- ══════════════════════════════════════════════════════════ -->

        <!-- /teleop_echo (WSL2) -->
        <mxCell id="teleop_echo" value="/teleop_echo&#xa;(dt_send stamped)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;strokeWidth=2;" vertex="1" parent="1">
